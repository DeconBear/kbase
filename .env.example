# KBase — local debug credentials
#
# Copy this file to `.env.local` (NOT `.env`, so git can never see your
# keys) and fill in the values you want for source-mode debugging.
#
#   cp .env.example .env.local
#
# Precedence on launch (later wins over earlier, only when not yet in
# os.environ):
#   1. .env             — shared team defaults (not used by KBase today)
#   2. .env.local       — your private overrides (this is where keys go)
#   3. data/local.env   — managed by Settings UI; takes effect last
#
# All of these files are gitignored. Do not commit real keys.

# --- LLM (chat / metadata / translation) -----------------------------------
# DeepSeek example:
# LLM_API_KEY=sk-...
# LLM_API_URL=https://api.deepseek.com/v1/chat/completions
# LLM_MODEL=deepseek-chat

# --- DocParser (cloud GPU PDF parsing) -------------------------------------
# DOCPARSER_API_URL=https://your-cloud-parser.com
# DOCPARSER_API_KEY=
# DOCPARSER_ENGINE=struct

# --- DocMind (Alibaba cloud) -----------------------------------------------
# DOCMIND_ACCESS_KEY_ID=
# DOCMIND_ACCESS_KEY_SECRET=
# DOCMIND_REGION=cn-hangzhou

# --- Generic cloud OCR (per-page PNG) --------------------------------------
# OCR_API_URL=https://your-ocr-provider.com/v1/ocr
# OCR_API_KEY=
# OCR_PROVIDER=yunzhisheng
# OCR_LANG=zh-CN+en

# --- Unisound U1 Doc Parser (async PDF -> Markdown) ------------------------
# Get a Token Plan key at https://maas.unisound.com/
UNISOUND_API_KEY=
UNISOUND_BASE_URL=https://maas-api.hivoice.cn
UNISOUND_MODEL=u1-ocr
