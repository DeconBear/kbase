# OpenAI-compatible API (can also be configured in the app settings)
LLM_API_KEY=sk-your-key-here
LLM_API_URL=https://api.deepseek.com/v1/chat/completions
LLM_MODEL=deepseek-v4-flash

# Alibaba Cloud DocMind API (RAM access with AK/SK)
DOCMIND_ACCESS_KEY_ID=your-access-key-id
DOCMIND_ACCESS_KEY_SECRET=your-access-key-secret
DOCMIND_REGION=cn-hangzhou

# DeconBear DocParser API (cloud GPU-accelerated PDF parsing)
DOCPARSER_API_KEY=dp_your-api-key-here
# Sub-engine: "struct" (academic papers, default) or "polyglot" (Chinese/multilingual)
DOCPARSER_ENGINE=struct
# Custom API endpoint (optional, defaults to https://docparser.deconbear.cn)
# DOCPARSER_API_URL=https://docparser.deconbear.cn
